# Normalize line endings for all text files
* text=auto eol=lf

# Java / Gradle source
*.java text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf

# Shell scripts
*.sh text eol=lf
*.bat text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.ogg binary
*.wav binary
*.mp3 binary
*.ttf binary
*.otf binary
*.keystore binary
*.jks binary
*.jar binary
*.apk binary
*.aab binary
